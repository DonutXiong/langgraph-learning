# DeepSeek 模型配置
# 使用 OpenAI 兼容的 API 格式
LANGCHAIN_MODEL=openai:deepseek-chat
OPENAI_API_KEY=your_deepseek_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com

# 可选: 开启 LangSmith 追踪
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=langgraph-learning

# 注意:
# 1. 将 your_deepseek_api_key_here 替换为你的 DeepSeek API Key
# 2. DeepSeek 使用 OpenAI 兼容的 API，所以使用 openai: 前缀
# 3. 需要指定 OPENAI_BASE_URL 为 DeepSeek 的 API 地址
# 4. 模型名称使用 deepseek-chat（或其他支持的模型）
